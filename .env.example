APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_RESPONSE_FORMAT=1.9.5

APPWRITE_DATABASE_ID=tim_cpg_insights
APPWRITE_SCORECARD_TABLE_ID=scorecard_rows
APPWRITE_IMPORT_RUNS_TABLE_ID=import_runs

# Optional comma-separated Appwrite permission strings for frontend reads.
# Example: read("team:tim_cpg_viewers")
APPWRITE_TABLE_PERMISSIONS=

# Keep this at 100 for Appwrite Free. Pro can use 1000.
APPWRITE_BULK_BATCH_SIZE=100

